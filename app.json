{
  "expo": {
    "name": "Среди Своих",
    "slug": "sredi-svoih-app",
    "scheme": "sredi-svoih",
    "version": "1.0.0",
    "orientation": "portrait",
    "ios": {
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
