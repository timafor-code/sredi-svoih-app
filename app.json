{
  "expo": {
    "name": "Среди Своих",
    "slug": "sredi-svoih-app",
    "scheme": "sredi-svoih",
    "version": "1.0.0",
    "orientation": "portrait",
    "web": {
      "output": "single",
      "bundler": "metro",
      "favicon": "./assets/logo.png"
    },
    "ios": {
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/app-stage"
    }
  }
}
