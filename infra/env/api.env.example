# Backend-only local API contour configuration.
# Do not copy these values into mobile, Expo, Vite, or apps/admin env files.
POSTGRES_DB=sredi_api
POSTGRES_USER=sredi_api
POSTGRES_PASSWORD=sredi_api
APP_NAME=sredi-svoih-api
APP_ENV=local
API_VERSION=0.1.0-local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://sredi_api:sredi_api@api_postgres:5432/sredi_api
API_JWT_SECRET=local-dev-jwt-secret-change-me-minimum-32-bytes
API_ACCESS_TOKEN_TTL_MINUTES=15
API_REFRESH_TOKEN_TTL_DAYS=30
API_TOKEN_HASH_SECRET=local-dev-token-hash-secret-change-me-minimum-32-bytes
API_JWT_ISSUER=sredi-svoih-api
API_JWT_AUDIENCE=
API_EMAIL_ENABLED=false
API_EMAIL_FROM_ADDRESS=dev-null@example.invalid
API_EMAIL_FROM_NAME=Sredi Svoih
API_EMAIL_SMTP_HOST=
API_EMAIL_SMTP_PORT=587
API_EMAIL_SMTP_USERNAME=
API_EMAIL_SMTP_PASSWORD=
API_EMAIL_SMTP_STARTTLS=true
API_AUTH_EMAIL_RATE_LIMIT_WINDOW_SECONDS=900
API_AUTH_EMAIL_RATE_LIMIT_MAX_ATTEMPTS=5
API_PUBLIC_APP_BASE_URL=http://localhost:8081
