# Backend-only local API configuration. Do not copy these values into mobile,
# Expo, Vite, or apps/admin environment files.
APP_NAME=sredi-svoih-api
APP_ENV=local
API_VERSION=0.1.0-local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://sredi_api:sredi_api@localhost:55432/sredi_api
MIGRATION_ACCEPT_SUPABASE_JWT=false
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=
