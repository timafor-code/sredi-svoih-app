VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Python API base URL. Required for pages already switched to the Python API,
# for example Admin Center -> "Импорт с сайта". Local docker compose exposes
# api_backend on port 8000.
VITE_API_URL=http://127.0.0.1:8000

# Optional visual label for the admin UI, for example: staging, prod, local.
VITE_ADMIN_ENV_LABEL=staging

# Optional Vite base path for static hosting under a subpath.
# Keep "/" for local development; staging uses "/admin-stage/" in .env.production.local.
VITE_ADMIN_BASE_PATH=/

# Python API is the production default for all migrated admin domains. Set an
# individual provider to supabase only for the explicit legacy/dev fallback.
VITE_AUTH_PROVIDER=api
VITE_ADMIN_EVENTS_PROVIDER=api
VITE_ADMIN_REGISTRATIONS_PROVIDER=api
VITE_ADMIN_MEMBERS_PROVIDER=api
VITE_ADMIN_INVITES_PROVIDER=api
VITE_ADMIN_SEATING_PROVIDER=api
VITE_ADMIN_IMPORT_PROVIDER=api
VITE_ADMIN_FEEDBACK_PROVIDER=api
VITE_ADMIN_COMMUNITY_PROVIDER=api
