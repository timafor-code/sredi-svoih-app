EXPO_PUBLIC_SUPABASE_URL=http://YOUR_LOCAL_IP:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Mobile domain providers stay on Supabase until the final backend cutover.
# Set a single domain to api only for local, synthetic staging, or controlled
# migration testing.
EXPO_PUBLIC_PRIVACY_PROVIDER=supabase
EXPO_PUBLIC_DEVICE_PROVIDER=supabase

# Expo Go on iPhone must reach the API through the development computer's LAN
# address; do not use a loopback address here.
EXPO_PUBLIC_API_URL=http://<computer-lan-ip>:8000
