EXPO_PUBLIC_SUPABASE_URL=http://YOUR_LOCAL_IP:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Python API is the production default for all migrated mobile domains.
# Set an individual provider to supabase only for the explicit legacy/dev fallback.
EXPO_PUBLIC_AUTH_PROVIDER=api
EXPO_PUBLIC_EVENTS_PROVIDER=api
EXPO_PUBLIC_REGISTRATIONS_PROVIDER=api
EXPO_PUBLIC_PRAYER_PROVIDER=api
EXPO_PUBLIC_CONTACTS_PROVIDER=api
EXPO_PUBLIC_AVATAR_PROVIDER=api
EXPO_PUBLIC_DEVICE_PROVIDER=api

# Required for API-default production and Expo Go deployments. Expo Go on iPhone
# must reach the API through the development computer's LAN address; do not use
# a loopback address there.
EXPO_PUBLIC_API_URL=http://<computer-lan-ip>:8000
